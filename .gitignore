# ── lerobot 본체 (별도 clone, 벤더링 안 함) ─────────────────────
# README 의 setup 대로 `git clone ... && git checkout v0.4.4` 로 직접 받는다.
# (완전 무수정 원칙이라 특정 커밋만 고정하면 재현됨)
/lerobot/

# ── 실행 산출물 (로그·JSON·gif·체크포인트) ─────────────────────
# 폴더 구조만 유지하고 내용물은 무시.
/outputs/**
!/outputs/
!/outputs/.gitkeep

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg-link
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# ── 가상환경 (혹시 repo 안에 만들 경우) ────────────────────────
.venv/
venv/
env/

# ── 실험 추적 / 대용량 아티팩트 ───────────────────────────────
wandb/
*.ckpt
*.pt
*.pth

# ── 노트북 체크포인트 ─────────────────────────────────────────
.ipynb_checkpoints/

# ── 에디터 / OS ───────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
*.swp
